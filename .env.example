# URL canonique publique, sans slash final
NEXT_PUBLIC_SITE_URL=https://solar-scope.vercel.app

# Les fonctions NASA marchent avec DEMO_KEY, mais une clé dédiée offre plus de quota.
NASA_API_KEY=DEMO_KEY

# Facultatif : SolarBot conserve un mode éducatif local si Gemini est indisponible.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Secret long et aléatoire utilisé par Vercel Cron pour /api/refresh.
CRON_SECRET=
