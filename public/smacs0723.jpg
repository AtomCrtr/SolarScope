<div id="" class=" hds-module hds-module-full alignfull wp-block-nasa-blocks-listicle">
	<div class="hds-listicle bg-spacesuit-white maxw-full width-full padding-0 color-mode-blue nasa-gb-align-full">
		<div class="hds-listicle-wrapper padding-y-4 padding-x-3">
			<h2 class="hds-listicle-heading"><strong>Do NASA Science with Galaxy Zoo!</strong></h2>

			<div class="grid-row grid-gap-2">

				
				<div class="grid-col-12 listicle-layout-basic">

					<ul>
						
						<li class="grid-row grid-gap-2 padding-bottom-2">

							<div class="grid-col-12">

								<div class="hds-listicle-text-wrapper">

									
									<div class="hds-listicle-list-text">

										<h3 class="heading-22"><strong>Join NASA researchers and help discover the secrets of the universe.</strong></h3>
										<p class="hds-listicle-list-description">
											NASA invites people of all ages and backgrounds to participate in authentic NASA research via "citizen science" or "participatory science" projects, where volunteers and amateurs have helped make thousands of important scientific discoveries! As a part of the Galaxy Zoo project, you can help classify the latest images of galaxies from NASA's Webb telescope.										</p>

																				<p>											
														<a href="https://science.nasa.gov/citizen-science/galaxy-zoo/" target="_self" class="button-primary button-primary-sm hds-listicle-button link-external-false">
			<span class="line-height-alt-1 " >
				Learn how you can get involved                			</span>
			<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><circle class="button-primary-circle" cx="16" cy="16" r="16"></circle><path d="M8 16.956h12.604l-3.844 4.106 1.252 1.338L24 16l-5.988-6.4-1.252 1.338 3.844 4.106H8v1.912z" class="color-spacesuit-white"></path></svg>
		</a>
												</p>
										
									</div>
								</div>
							</div>

							
						</li>
													
					</ul>
				</div>

				
			</div>

		</div>
	</div>

	</div>

